\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Phase A source comparison (Shared JL; same AudioCaps Phase~B for all rows). COCO-sub-100K (20K images, 5 captions each) outperforms CC3M-100K at $m \in \{64, 256, 512\}$ and outperforms COCO-full-566K at every tested dimension. CC3M-100K wins only at $m=128$, where image diversity outweighs caption precision in the low-dimension regime. Increasing Phase~A volume beyond $\approx $100K pairs does not improve transfer at any tested dimension (COCO-full-566K never dominates COCO-sub-100K). (Chance at $\overline  {R}=0.0011$, dashed.)}}{15}{figure.caption.52}\protected@file@percent }
\newlabel{fig:phaseaquality}{{5}{15}{Phase A source comparison (Shared JL; same AudioCaps Phase~B for all rows). COCO-sub-100K (20K images, 5 captions each) outperforms CC3M-100K at $m \in \{64, 256, 512\}$ and outperforms COCO-full-566K at every tested dimension. CC3M-100K wins only at $m=128$, where image diversity outweighs caption precision in the low-dimension regime. Increasing Phase~A volume beyond $\approx $100K pairs does not improve transfer at any tested dimension (COCO-full-566K never dominates COCO-sub-100K). (Chance at $\avgR =0.0011$, dashed.)}{figure.caption.52}{}}
