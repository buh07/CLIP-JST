\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces Two-phase text-anchored protocol. Phase~A trains image and text heads ($f_v$, $f_t$) jointly on COCO with InfoNCE, then freezes them. Phase~B trains an audio head ($f_a$) on AudioCaps using the frozen $f_t$ as a semantic bridge---audio and image are never paired during training. At inference, $f_v$ and $f_a$ are composed directly for zero-shot image-audio retrieval. Frozen components are shown with dashed borders.}}{3}{figure.caption.8}\protected@file@percent }
\providecommand*\caption@xref[2]{\@setref\relax\@undefined{#1}}
\newlabel{fig:architecture}{{1}{3}{Two-phase text-anchored protocol. Phase~A trains image and text heads ($f_v$, $f_t$) jointly on COCO with InfoNCE, then freezes them. Phase~B trains an audio head ($f_a$) on AudioCaps using the frozen $f_t$ as a semantic bridge---audio and image are never paired during training. At inference, $f_v$ and $f_a$ are composed directly for zero-shot image-audio retrieval. Frozen components are shown with dashed borders}{figure.caption.8}{}}
